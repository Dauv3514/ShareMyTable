# Ports exposés uniquement sur localhost du VPS
FRONTEND_PORT=8088
BACKEND_PORT=3008

# Base PostgreSQL Docker
POSTGRES_DB=ramenetapoire
POSTGRES_USER=ramenetapoire
POSTGRES_PASSWORD=change_me_strong_password

# Backend NestJS
NODE_ENV=production
PORT=5001
API_GLOBAL_PREFIX=api
TYPEORM_SYNCHRONIZE=false
DATABASE_URL=postgres://ramenetapoire:change_me_strong_password@db:5432/ramenetapoire

# URLs publiques
FRONTEND_URL=https://ramenetapoire.bouchard-mehdi.fr
BACKEND_URL=https://ramenetapoire.bouchard-mehdi.fr
PUBLIC_API_URL=https://ramenetapoire.bouchard-mehdi.fr/api
NEXT_PUBLIC_API_URL=https://ramenetapoire.bouchard-mehdi.fr/api
NEXT_PUBLIC_BACKEND_URL=https://ramenetapoire.bouchard-mehdi.fr
INTERNAL_API_URL=http://backend:5001/api

# Auth
JWT_SECRET=change_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Email
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
BREVO_SMTP_USER=change_me
BREVO_SMTP_KEY=change_me
MAIL_FROM="RamèneTaPoire <contact@ramenetapoire.fr>"

# OAuth Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://ramenetapoire.bouchard-mehdi.fr/api/auth/google/callback

# OAuth Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=
APPLE_CALLBACK_URL=https://ramenetapoire.bouchard-mehdi.fr/api/auth/apple/callback

# Géocodage / vérification hôte
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=contact@ramenetapoire.fr
GOOGLE_VISION_ENABLED=false
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_VISION_CREDENTIALS_JSON=
GOOGLE_CLOUD_PROJECT=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Web Push / PWA
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@ramenetapoire.fr

# Seed de démonstration
# À activer uniquement sur une base de test ou une base de présentation.
ALLOW_DEMO_SEED=false
DEMO_SEED_RESET=false
DEMO_SEED_PASSWORD=DemoPassword123!
